# Vinland — Supabase template for future backend integration
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in real values:
#   cp .env.example .env   (Unix/macOS)
#   copy .env.example .env (Windows cmd)
#
# Find URL and keys in Supabase Dashboard → Project Settings → API.
#
# Expo (SDK 49+) inlines only variables whose names start with EXPO_PUBLIC_
# into the JS bundle. Treat those as public (anon key is designed for browsers).
# Never prefix or ship the service role key to the app — use it only in secure
# server, Edge Functions, or local scripts.

EXPO_PUBLIC_SUPABASE_URL=
# Prefer publishable key from Dashboard → API (sb_publishable_...); else use anon JWT:
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Optional — backend/CI/scripts only (omit from mobile/web client code):
# SUPABASE_SERVICE_ROLE_KEY=
